{
  "name": "esbuild-plugin-lingui-react-email-macro",
  "version": "1.0.1",
  "description": "An esbuild plugin to transform Lingui macros in React email.",
  "author": "Norbert Elter <norbert.elter0@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/itsyoboieltr/esbuild-plugin-lingui-react-email-macro#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsyoboieltr/esbuild-plugin-lingui-react-email-macro.git"
  },
  "bugs": "https://github.com/itsyoboieltr/esbuild-plugin-lingui-react-email-macro/issues",
  "keywords": [
    "esbuild-plugin",
    "lingui",
    "react-email"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
